# ==================== VERIDACTUS 前端环境变量 ====================
# 复制此文件为 .env.local 并修改

# 控制面地址 (默认 127.0.0.1:8081)
VITE_CP_HOST=127.0.0.1:8081

# 数据面地址 (默认 127.0.0.1:8080)
VITE_DP_HOST=127.0.0.1:8080

# Python Worker 地址 (默认 127.0.0.1:8001)
VITE_PW_HOST=127.0.0.1:8001

# API 基础路径 (留空使用 vite proxy，生产部署时设置为实际 API 地址)
# VITE_API_URL=https://api.veridactus.example.com

# ==================== 可选 ====================
# 默认主题 (dark | light)
# VITE_DEFAULT_THEME=dark
