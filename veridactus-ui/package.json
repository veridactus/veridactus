{
  "name": "veridactus-ui",
  "private": true,
  "version": "0.2.1",
  "type": "module",
  "description": "VERIDACTUS Frontend - AI Execution Governance UI",
  "scripts": {
    "dev": "vite --port 3000",
    "build": "tsc -b && vite build",
