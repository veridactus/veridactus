# =============================================================================
# VERIDACTUS Environment Configuration
# Copy this file to .env and modify as needed
#
# Project: VERIDACTUS - Trusted AI Execution Governance
# License: Apache-2.0
# Source: https://github.com/veridactus/veridactus
# =============================================================================

# ==================== Security Warning ====================
# NEVER commit this file with real credentials!
# Use .env.local or secrets management in production.
# ==========================================================

# ==================== 🔐 CRITICAL: Cryptographic Secrets ====================
# WARNING: Changing these keys has irreversible consequences:
#   JWT_SECRET       → All users forced to re-login
#   MASTER_KEY       → All encrypted Provider API Keys become unrecoverable
# Generate with:     openssl rand -base64 32
# =============================================================================
JWT_SECRET=change-me-generate-with-openssl-rand-base64-32
VERIDACTUS_MASTER_KEY=change-me-generate-with-openssl-rand-base64-32
VERIDACTUS_ENV=development

# ==================== Control Plane ====================
VERIDACTUS_ADMIN_KEY=veridactus-admin-2026-change-this-in-production
VERIDACTUS_CP_PORT=8081
VERIDACTUS_CP_DB_PATH=/app/veridactus.db
VERIDACTUS_CP_CORS_ORIGINS=http://localhost:3000,http://localhost:8080,http://127.0.0.1:3000

# ==================== Data Plane ====================
VERIDACTUS_MODE=passthrough
VERIDACTUS_UPSTREAM_URL=https://open.bigmodel.cn
VERIDACTUS_UPSTREAM_KEY=your-llm-api-key-change-this
VERIDACTUS_CONTROL_PLANE_URL=http://veridactus-cp:8081
VERIDACTUS_STORE_BACKEND=postgres
DATABASE_URL=postgres://veridactus:veridactus2026-change-this-in-production@postgres:5432/veridactus
# Data Plane Admin Key（与 CP 的 VERIDACTUS_ADMIN_KEY 一致，用于 Chat 治理模式）
VERIDACTUS_ADMIN_KEY=veridactus-admin-dev-2026
RUST_LOG=info

# ==================== Storage Backend ====================
# Options: memory | file | postgres
VERIDACTUS_STORE_BACKEND=postgres

# ==================== PostgreSQL ====================
POSTGRES_PASSWORD=veridactus2026-change-this-in-production
VERIDACTUS_STORE_POSTGRES_HOST=postgres
VERIDACTUS_STORE_POSTGRES_PORT=5432
VERIDACTUS_STORE_POSTGRES_DB=veridactus
VERIDACTUS_STORE_POSTGRES_USER=veridactus
DATABASE_URL=postgres://veridactus:veridactus2026-change-this-in-production@postgres:5432/veridactus

# ==================== Redis ====================
VERIDACTUS_STORE_REDIS_HOST=redis
VERIDACTUS_STORE_REDIS_PORT=6379

# ==================== MinIO/S3 ====================
MINIO_ROOT_USER=veridactus
MINIO_ROOT_PASSWORD=veridactus123-change-this-in-production
MINIO_REGION=us-east-1
VERIDACTUS_STORE_S3_ENDPOINT=http://minio:9000
VERIDACTUS_STORE_S3_BUCKET=veridactus
VERIDACTUS_STORE_S3_ACCESS_KEY=veridactus
VERIDACTUS_STORE_S3_SECRET_KEY=veridactus123-change-this-in-production
VERIDACTUS_STORE_S3_REGION=us-east-1

# ==================== CORS ====================
CORS_ORIGINS=http://localhost:3000,http://localhost:8080,http://127.0.0.1:3000

# ==================== Timezone ====================
TIMEZONE=UTC

# ==================== Worker Configuration ====================
WORKER_LOG_LEVEL=info

# ==================== Optional: LLM API Keys ====================
# Zhipu AI (for glm-5.1)
VERIDACTUS_ZHIPU_API_KEY=your-zhipu-api-key

# Google Gemini
VERIDACTUS_GEMINI_API_KEY=your-gemini-api-key

# Azure AI
VERIDACTUS_AZURE_AI_API_KEY=your-azure-ai-api-key

# Baidu Ernie
VERIDACTUS_ERNIE_API_KEY=your-ernie-api-key

# ==================== Optional: Proxy Configuration ====================
VERIDACTUS_PROXY_URL=

# ==================== Optional: Static API Keys ====================
# Format: name:key,name:key
# VERIDACTUS_STATIC_API_KEYS=client1:sk-client1-key,client2:sk-client2-key

# ==================== Development Settings ====================
# Enable debug mode (not recommended for production)
# VERIDACTUS_DEBUG=true
